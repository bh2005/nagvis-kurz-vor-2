# =============================================
# NagVis 2 – Environment Variablen (Beispiel)
# =============================================

# === Allgemein ===
DEBUG=true
ENVIRONMENT=development          # development | production

# === Server ===
HOST=0.0.0.0
PORT=8000
UVICORN_WORKERS=1                # in Prod auf 4+ erhöhen

# === Livestatus / Backend ===
LIVE_STATUS_HOST=127.0.0.1
LIVE_STATUS_PORT=6557
CHECKMK_SITE=mysite              # nur bei Checkmk/OMD nötig, sonst leer lassen

# === Pfade ===
DATA_DIR=./data
MAPS_DIR=./data/maps
BACKGROUNDS_DIR=./data/backgrounds
TOKENS_FILE=./data/tokens.json

# === Sicherheit ===
SECRET_KEY=supersecret-change-me-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === CORS (für lokale Entwicklung) ===
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# === Demo / Kiosk ===
DEMO_MODE=false                  # wird automatisch erkannt, kann aber überschrieben werden
KIOSK_DEFAULT_INTERVAL=30