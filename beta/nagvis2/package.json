{
  "name": "nagvis2",
  "version": "0.1.0",
  "description": "NagVis 2 - Modernäres Web-Interface für Nagios/Checkmk/Icinga (Help + Backend)",
  "private": true,
  "scripts": {
    "docs:build": "python -m mkdocs build -f mkdocs.yml -d frontend/help",
    "docs:serve": "python -m mkdocs serve -f mkdocs.yml",
    "backend:start": "cd backend && python -m uvicorn main:app --host 0.0.0.0 --port 8008 --reload",
    "backend:lint": "cd backend && python -m py_compile **/*.py"
  },
  "author": "bh2005",
  "license": "GPL-2.0-only"
}
