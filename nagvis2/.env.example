# =============================================
# NagVis 2 – Environment Variablen (Beispiel)
# Kopiere diese Datei nach .env und passe sie an.
# .env liegt im backend/-Verzeichnis.
# =============================================

# === Umgebung ===
DEBUG=true                       # false in Produktion (kein Auto-Reload)
ENVIRONMENT=development          # development | production

# === Server ===
HOST=0.0.0.0
PORT=8008
UVICORN_WORKERS=1                # in Prod auf CPU-Kernanzahl erhöhen

# === Livestatus ===
LIVESTATUS_TYPE=auto             # auto | tcp | unix | disabled
LIVESTATUS_HOST=127.0.0.1
LIVESTATUS_PORT=6557
LIVESTATUS_PATH=/var/run/nagios/live   # nur bei type=unix
LIVESTATUS_SITE=                 # OMD-Site-Name (z.B. mysite) → beschleunigt Auto-Detect

# === WebSocket ===
WS_POLL_INTERVAL=10              # Sekunden zwischen Backend-Abfragen

# === Logging ===
LOG_FORMAT=text                  # text | json (json für ELK/Loki/Splunk)
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_BUFFER_LINES=1000            # In-Memory-Ringpuffer (0 = deaktiviert)

# === Authentifizierung ===
# AUTH_ENABLED=false  → App läuft offen, alle Benutzer sind implizit Admin.
#                       Schutz sollte dann über nginx / OMD-Basis-Auth erfolgen.
# AUTH_ENABLED=true   → Login-Overlay aktiv, alle API-Endpunkte prüfen JWT-Token.
#                       NAGVIS_SECRET MUSS in Produktion gesetzt sein!
AUTH_ENABLED=false

# JWT-Signing-Key – MUSS bei AUTH_ENABLED=true geändert werden!
# Erzeugen z.B. mit: python3 -c "import secrets; print(secrets.token_hex(32))"
NAGVIS_SECRET=bitte-in-produktion-aendern

# === CORS (für lokale Entwicklung) ===
CORS_ORIGINS=http://localhost:8008,http://localhost:3000

# === Demo / Kiosk ===
DEMO_MODE=false                  # true: simulierte Daten, kein echtes Backend nötig
KIOSK_DEFAULT_INTERVAL=30        # Sekunden zwischen Map-Wechsel im Kiosk-Modus
